{
    "name": "onenote-to-obsidian",
    "version": "1.0.0",
    "description": "Export OneNote notebooks to Obsidian-compatible Markdown using Playwright",
    "main": "electron/main.js",
    "bin": {
        "onenote-export": "./src/index.js"
    },
    "scripts": {
        "start": "node src/index.js",
        "electron:dev": "electron .",
        "electron:build": "electron-builder",
        "electron:build:mac": "electron-builder --mac",
        "electron:build:win": "electron-builder --win",
        "electron:build:linux": "electron-builder --linux",
        "clean": "rm -rf node_modules .jest-cache .test-temp .tmp debug_*.html .DS_Store logs *.log dist build coverage",
        "cleanfull": "rm -rf node_modules output .jest-cache .test-temp .tmp auth.json debug_*.html .DS_Store logs *.log dist build coverage",
        "test": "jest",
        "test:watch": "jest --watch"
    },
    "keywords": [
        "onenote",
        "obsidian",
        "export",
        "markdown",
        "playwright",
        "electron"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "chalk": "^4.1.2",
        "cli-progress": "^3.12.0",
        "commander": "^14.0.3",
        "enquirer": "^2.4.1",
        "fs-extra": "^11.3.3",
        "playwright": "^1.58.1",
        "sanitize-filename": "^1.6.3",
        "turndown": "^7.2.2",
        "turndown-plugin-gfm": "^1.0.2"
    },
    "devDependencies": {
        "electron": "^41.0.3",
        "electron-builder": "^26.8.1",
        "jest": "^29.7.0",
        "jsdom": "^28.0.0"
    },
    "build": {
        "appId": "com.onenote.exporter",
        "productName": "OneNote Exporter",
        "copyright": "Copyright © 2026",
        "files": [
            "electron/**/*",
            "src/**/*",
            "node_modules/**/*",
            "!node_modules/.cache/**/*"
        ],
        "directories": {
            "output": "dist"
        },
        "mac": {
            "target": [
                { "target": "dmg", "arch": ["x64", "arm64"] }
            ],
            "icon": "build/icon.icns",
            "category": "public.app-category.productivity"
        },
        "win": {
            "target": [
                { "target": "nsis", "arch": ["x64"] }
            ],
            "icon": "build/icon.png"
        },
        "linux": {
            "target": [
                { "target": "AppImage", "arch": ["x64"] }
            ],
            "icon": "build/icon.png",
            "category": "Office"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
